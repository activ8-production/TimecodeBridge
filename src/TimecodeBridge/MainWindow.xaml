<Window x:Class="TimecodeBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimecodeBridge"
        xmlns:views="clr-namespace:TimecodeBridge.Views"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="768" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PrimaryBackgroundBrush}">
    <Grid Background="{DynamicResource PrimaryBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規プロジェクト(_N)" Command="{Binding NewProjectCommand}" />
                <Separator />
                <MenuItem Header="開く(_O)" x:Name="OpenMenuItem" Click="OpenMenuItem_Click" />
                <MenuItem Header="保存(_S)" Command="{Binding SaveProjectCommand}" />
                <MenuItem Header="名前を付けて保存(_A)" x:Name="SaveAsMenuItem" Click="SaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="最近のプロジェクト" x:Name="RecentProjectsMenuItem"
                          ItemsSource="{Binding RecentProjects}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command" Value="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="背景画像を設定..." x:Name="SetBackgroundMenuItem" Click="SetBackgroundMenuItem_Click" />
                <MenuItem Header="背景画像をクリア" Command="{Binding ClearBackgroundImageCommand}" />
                <Separator />
                <MenuItem Header="暗さ調整">
                    <MenuItem.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </MenuItem.ItemsPanel>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="明るい" VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,0,8,0" />
                        <Slider x:Name="DarkenSlider" Width="150" Minimum="0" Maximum="0.95"
                                Value="{Binding BackgroundDarkenOpacity, Mode=TwoWay}"
                                VerticalAlignment="Center" />
                        <TextBlock Text="暗い" VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="8,0,0,0" />
                    </StackPanel>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Row 1: CueList (left) + HostManager / RelayControl / BackgroundImage (right) -->
        <Grid Grid.Row="1" Margin="4,4,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Left: CueList -->
            <views:CueListView Grid.Column="0" x:Name="CueList" />

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right: HostManager + RelayControl + Background Image -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent" Margin="4,0,0,0">
                <StackPanel>
                    <views:HostManagerView x:Name="HostManager" Margin="0,0,0,4" />
                    <views:RelayControlView x:Name="RelayControl" Margin="0,0,0,4" />

                    <!-- Background Image (compact) -->
                    <Border Margin="0,0,0,4"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                            Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                            Visibility="{Binding BackgroundImagePath, Converter={StaticResource NullToCollapsedConverter}}">
                        <Grid ClipToBounds="True">
                            <Image x:Name="BackgroundImage"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   MaxHeight="200" />
                            <Rectangle Fill="#000000"
                                       Opacity="{Binding BackgroundDarkenOpacity}"
                                       RadiusX="7" RadiusY="7" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Row 2: TC + Waveform (left) | Log (right) -->
        <Grid Grid.Row="2" Margin="4,4,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Timecode + Waveform (stretch to fill row height) -->
            <Grid Grid.Column="0" Margin="0,0,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <views:TimecodeDisplayView Grid.Row="0" x:Name="TimecodeDisplay" />
                <views:AudioWaveformView Grid.Row="1" x:Name="AudioWaveform" Height="46" />
            </Grid>

            <!-- Right: Log Panel -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="8" Background="{DynamicResource CardBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="12,8,12,4">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" Height="14" Background="{DynamicResource AccentBrush}"
                                    CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="ログ" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource PrimaryForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Content="クリア" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Padding="10,4" FontSize="11"
                                x:Name="ClearLogButton" />
                    </DockPanel>
                    <ListView Grid.Row="1" x:Name="LogListView"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="4,0,4,4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Message}" FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
