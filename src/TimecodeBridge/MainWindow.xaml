<Window x:Class="TimecodeBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimecodeBridge"
        xmlns:views="clr-namespace:TimecodeBridge.Views"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="768" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <!-- Row 0: Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規プロジェクト(_N)" Command="{Binding NewProjectCommand}" />
                <Separator />
                <MenuItem Header="開く(_O)" x:Name="OpenMenuItem" Click="OpenMenuItem_Click" />
                <MenuItem Header="保存(_S)" Command="{Binding SaveProjectCommand}" />
                <MenuItem Header="名前を付けて保存(_A)" x:Name="SaveAsMenuItem" Click="SaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="最近のプロジェクト" x:Name="RecentProjectsMenuItem"
                          ItemsSource="{Binding RecentProjects}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command" Value="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Row 1: Timecode Display + Waveform -->
        <StackPanel Grid.Row="1">
            <views:TimecodeDisplayView x:Name="TimecodeDisplay" />
            <views:AudioWaveformView x:Name="AudioWaveform" Height="70" />
        </StackPanel>

        <!-- Row 2: CueList + Right Side Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- CueList -->
            <views:CueListView Grid.Column="0" x:Name="CueList" />

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right Side Panel: HostManager + RelayControl -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- HostManagerView -->
                    <views:HostManagerView x:Name="HostManager" Margin="2" />

                    <!-- RelayControlView -->
                    <views:RelayControlView x:Name="RelayControl" Margin="2" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Row 3: Splitter -->
        <GridSplitter Grid.Row="3" Height="4"
                      Background="{DynamicResource BorderBrush}"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center" />

        <!-- Row 4: Log Panel -->
        <Border Grid.Row="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="8,4">
                    <TextBlock Text="ログ" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}"
                               VerticalAlignment="Center" />
                    <Button Content="クリア" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Padding="8,2" FontSize="11"
                            x:Name="ClearLogButton" />
                </DockPanel>
                <ListView Grid.Row="1" x:Name="LogListView"
                          Background="{DynamicResource SecondaryBackgroundBrush}"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Message}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource PrimaryForegroundBrush}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
