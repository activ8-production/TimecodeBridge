<Window x:Class="TimecodeBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimecodeBridge"
        xmlns:views="clr-namespace:TimecodeBridge.Views"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="768" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <!-- Row 0: Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規プロジェクト(_N)" Command="{Binding NewProjectCommand}" />
                <Separator />
                <MenuItem Header="開く(_O)" x:Name="OpenMenuItem" Click="OpenMenuItem_Click" />
                <MenuItem Header="保存(_S)" Command="{Binding SaveProjectCommand}" />
                <MenuItem Header="名前を付けて保存(_A)" x:Name="SaveAsMenuItem" Click="SaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="最近のプロジェクト" x:Name="RecentProjectsMenuItem"
                          ItemsSource="{Binding RecentProjects}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command" Value="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="背景画像を設定..." x:Name="SetBackgroundMenuItem" Click="SetBackgroundMenuItem_Click" />
                <MenuItem Header="背景画像をクリア" Command="{Binding ClearBackgroundImageCommand}" />
                <Separator />
                <MenuItem Header="暗さ調整">
                    <MenuItem.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </MenuItem.ItemsPanel>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="明るい" VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,0,8,0" />
                        <Slider x:Name="DarkenSlider" Width="150" Minimum="0" Maximum="0.95"
                                Value="{Binding BackgroundDarkenOpacity, Mode=TwoWay}"
                                VerticalAlignment="Center" />
                        <TextBlock Text="暗い" VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="8,0,0,0" />
                    </StackPanel>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Row 1: Timecode Display + Background Image Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: Timecode + Waveform -->
            <StackPanel Grid.Column="0">
                <views:TimecodeDisplayView x:Name="TimecodeDisplay" />
                <views:AudioWaveformView x:Name="AudioWaveform" Height="70" />
            </StackPanel>

            <!-- Right: 16:9 Background Image Area -->
            <Border Grid.Column="1" Margin="2"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Background="#181828" CornerRadius="3"
                    Visibility="{Binding BackgroundImagePath, Converter={StaticResource NullToCollapsedConverter}}">
                <Grid Width="448" ClipToBounds="True">
                    <!-- 16:9 aspect ratio: 448 * 9/16 = 252 -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="252" />
                    </Grid.RowDefinitions>

                    <!-- Image -->
                    <Image x:Name="BackgroundImage"
                           Stretch="UniformToFill"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                    <!-- Darken overlay -->
                    <Rectangle Fill="#000000"
                               Opacity="{Binding BackgroundDarkenOpacity}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Row 2: CueList + Right Side Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- CueList -->
            <views:CueListView Grid.Column="0" x:Name="CueList" />

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right Side Panel: HostManager + RelayControl -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- HostManagerView -->
                    <views:HostManagerView x:Name="HostManager" Margin="2" />

                    <!-- RelayControlView -->
                    <views:RelayControlView x:Name="RelayControl" Margin="2" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Row 3: Splitter -->
        <GridSplitter Grid.Row="3" Height="4"
                      Background="{DynamicResource BorderBrush}"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center" />

        <!-- Row 4: Log Panel -->
        <Border Grid.Row="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="8,4">
                    <TextBlock Text="ログ" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}"
                               VerticalAlignment="Center" />
                    <Button Content="クリア" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Padding="8,2" FontSize="11"
                            x:Name="ClearLogButton" />
                </DockPanel>
                <ListView Grid.Row="1" x:Name="LogListView"
                          Background="{DynamicResource SecondaryBackgroundBrush}"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Message}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource PrimaryForegroundBrush}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
