<UserControl x:Class="TimecodeBridge.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TimecodeBridge.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LogViewModel, IsDesignTimeCreatable=False}"
             Background="{DynamicResource PrimaryBackgroundBrush}"
             Foreground="{DynamicResource PrimaryForegroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="ログ"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <!-- Log List -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Logs}"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource BorderBrush}"
                  x:Name="LogListView">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <!-- Timestamp -->
                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   Margin="0,0,12,0"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center" />

                        <!-- Message with success/failure color -->
                        <TextBlock Text="{Binding Message}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#4EC94E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Clear Button -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,8,0,0">
            <Button Content="ログクリア"
                    Command="{Binding ClearLogsCommand}"
                    Padding="12,6" />
        </StackPanel>
    </Grid>
</UserControl>
