<UserControl x:Class="TimecodeBridge.Views.RelayControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TimecodeBridge.ViewModels"
             xmlns:models="clr-namespace:TimecodeBridge.Models"
             xmlns:local="clr-namespace:TimecodeBridge.Views"
             xmlns:converters="clr-namespace:TimecodeBridge.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RelayViewModel, IsDesignTimeCreatable=False}"
             Background="Transparent"
             Foreground="{DynamicResource PrimaryForegroundBrush}">

    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1" CornerRadius="8" Padding="0">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="3" Height="14" Background="{DynamicResource AccentBrush}"
                        CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="リレー制御"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </StackPanel>

            <!-- OSC Address Pattern -->
            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="OSC アドレスパターン"
                           Margin="0,0,0,6"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <TextBox Text="{Binding OscAddressPattern, UpdateSourceTrigger=PropertyChanged}"
                         MaxWidth="300" FontFamily="Consolas"
                         HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Continuous Mode -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="継続送信モード"
                           Margin="0,0,0,6"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <ToggleButton Content="{Binding IsContinuousEnabled, Converter={x:Static converters:BoolToToggleLabelConverter.Instance}}"
                              IsChecked="{Binding IsContinuousEnabled}"
                              Padding="18,7"
                              HorizontalAlignment="Left"
                              x:Name="ContinuousToggle">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </StackPanel>

            <!-- Send Interval -->
            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                <TextBlock Text="送信間隔"
                           Margin="0,0,0,6"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="IntervalModeCombo"
                              SelectedIndex="0"
                              Width="140"
                              Margin="0,0,8,0">
                        <ComboBoxItem Content="EveryFrame" />
                        <ComboBoxItem Content="Custom" />
                    </ComboBox>
                    <TextBox Text="{Binding ContinuousInterval.IntervalMs, Mode=OneWay}"
                             Width="80"
                             IsEnabled="{Binding SelectedIndex, ElementName=IntervalModeCombo, Converter={x:Static converters:IndexToBoolConverter.Instance}}" />
                    <TextBlock Text="ms"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Target Hosts -->
            <StackPanel Grid.Row="4" Margin="0,0,0,12">
                <TextBlock Text="送信先ホスト"
                           Margin="0,0,0,6"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <ItemsControl ItemsSource="{Binding HostSelections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}"
                                      IsChecked="{Binding IsSelected}"
                                      Margin="0,3"
                                      Foreground="{DynamicResource PrimaryForegroundBrush}"
                                      Checked="OnHostCheckChanged"
                                      Unchecked="OnHostCheckChanged" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="(ホストが登録されていません)"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           FontSize="11"
                           Margin="0,3,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HostSelections.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- One-Shot Trigger -->
            <StackPanel Grid.Row="5">
                <TextBlock Text="ワンショット送信"
                           Margin="0,0,0,6"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <Button Content="送信トリガー"
                        Command="{Binding TriggerOneShotCommand}"
                        Padding="18,7" FontSize="12"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
