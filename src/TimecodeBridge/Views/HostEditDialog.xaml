<Window x:Class="TimecodeBridge.Views.HostEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ホスト編集"
        Width="360" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        Foreground="{DynamicResource PrimaryForegroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="名前" VerticalAlignment="Center" Margin="0,0,0,8" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="IPアドレス" VerticalAlignment="Center" Margin="0,0,0,8" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="IpAddressBox" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="ポート" VerticalAlignment="Center" Margin="0,0,0,8" />
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="PortBox" Margin="0,0,0,8" />

        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="EnabledBox" Content="有効" Margin="0,0,0,8" />

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Padding="20,6" Margin="0,0,8,0"
                    Click="OnOkClick" IsDefault="True" />
            <Button Content="キャンセル" Padding="20,6"
                    Click="OnCancelClick" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
