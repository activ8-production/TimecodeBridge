<UserControl x:Class="TimecodeBridge.Views.CueListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <Style x:Key="CueRowBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4,2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsNextCue}" Value="True">
                    <Setter Property="Background" Value="#2A3A5A8C" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <DockPanel Grid.Row="0" Margin="8,4">
                <TextBlock Text="キューリスト" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Trigger Window -->
                    <TextBlock Text="判定幅:" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                    <TextBox Text="{Binding TriggerWindowFrames, UpdateSourceTrigger=PropertyChanged}"
                             Width="36" FontSize="12" VerticalAlignment="Center"
                             HorizontalContentAlignment="Center" Padding="2,2" />
                    <TextBlock Text="f" VerticalAlignment="Center" Margin="2,0,12,0"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                    <Button Content="＋ 追加" Padding="10,3" Margin="4,0"
                            Command="{Binding AddCueCommand}" FontSize="12" />
                    <Button Content="編集" Padding="10,3" Margin="4,0"
                            Command="{Binding EditCueCommand}"
                            CommandParameter="{Binding SelectedItem.Id, ElementName=CueDataGrid}"
                            FontSize="12" />
                    <Button Content="複製" Padding="10,3" Margin="4,0"
                            Command="{Binding DuplicateCueCommand}"
                            CommandParameter="{Binding SelectedItem.Id, ElementName=CueDataGrid}"
                            FontSize="12" />
                    <Button Content="連続複製" Padding="10,3" Margin="4,0"
                            Command="{Binding BatchDuplicateCueCommand}"
                            CommandParameter="{Binding SelectedItem.Id, ElementName=CueDataGrid}"
                            FontSize="12" />
                    <Button Content="－ 削除" Padding="10,3" Margin="4,0"
                            Command="{Binding RemoveCueCommand}"
                            CommandParameter="{Binding SelectedItem.Id, ElementName=CueDataGrid}"
                            FontSize="12" />
                </StackPanel>
            </DockPanel>

            <!-- Cue List -->
            <ListView Grid.Row="1" x:Name="CueDataGrid"
                      ItemsSource="{Binding CueItems}"
                      Background="{DynamicResource SecondaryBackgroundBrush}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <!-- Enable/Disable Column -->
                        <GridViewColumn Header="有効" Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                              Command="{Binding DataContext.ToggleCueEnabledCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                              CommandParameter="{Binding Id}"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Trigger Time Column -->
                        <GridViewColumn Header="トリガー時間" Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TriggerTime}"
                                               FontFamily="Consolas" FontSize="13"
                                               Foreground="{DynamicResource PrimaryForegroundBrush}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Name Column -->
                        <GridViewColumn Header="名前" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource PrimaryForegroundBrush}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- OSC Address Column -->
                        <GridViewColumn Header="OSCアドレス" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OscAddress}"
                                               FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource SecondaryForegroundBrush}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Manual Trigger Column -->
                        <GridViewColumn Header="手動" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="▶" Padding="6,1" FontSize="11"
                                            Command="{Binding DataContext.ManualTriggerCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding Id}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

                <!-- Item container style for highlight effects -->
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <EventSetter Event="MouseDoubleClick" Handler="CueItem_MouseDoubleClick" />
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
                        <Setter Property="Padding" Value="2" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="RowBorder" Background="Transparent"
                                            Padding="{TemplateBinding Padding}" BorderThickness="0">
                                        <GridViewRowPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsNextCue}" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background"
                                                    Value="{DynamicResource SelectionBackgroundBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsTriggered}" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background"
                                                    Value="#5B9BD5" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background"
                                                    Value="{DynamicResource TertiaryBackgroundBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background"
                                                    Value="{DynamicResource SelectionBackgroundBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
    </Border>
</UserControl>
