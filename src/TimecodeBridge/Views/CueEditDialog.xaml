<Window x:Class="TimecodeBridge.Views.CueEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="キュー編集"
        Width="460" Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        Foreground="{DynamicResource PrimaryForegroundBrush}">

    <Border Margin="12" Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
            CornerRadius="8" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="名前" VerticalAlignment="Center" Margin="0,0,0,10"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="0,0,0,10" />

            <!-- Trigger Time -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="トリガー時間" VerticalAlignment="Center" Margin="0,0,0,10"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
            <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="HoursBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <TextBox Grid.Column="2" x:Name="MinutesBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" />
                <TextBlock Grid.Column="3" Text=":" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <TextBox Grid.Column="4" x:Name="SecondsBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" />
                <TextBlock Grid.Column="5" Text=":" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <TextBox Grid.Column="6" x:Name="FramesBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" />
            </Grid>

            <!-- Cue Offset -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="キューオフセット" VerticalAlignment="Center" Margin="0,0,0,10"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
            <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="OffsetSignBox" Width="44">
                    <ComboBoxItem Content="+" IsSelected="True" />
                    <ComboBoxItem Content="-" />
                </ComboBox>
                <TextBox Grid.Column="1" x:Name="OffsetHoursBox" TextAlignment="Center" MaxLength="2" Margin="4,0,0,0" FontFamily="Consolas" />
                <TextBlock Grid.Column="2" Text=":" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <TextBox Grid.Column="3" x:Name="OffsetMinutesBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" />
                <TextBlock Grid.Column="4" Text=":" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <TextBox Grid.Column="5" x:Name="OffsetSecondsBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" />
                <TextBlock Grid.Column="6" Text=":" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" />
                <TextBox Grid.Column="7" x:Name="OffsetFramesBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" />
            </Grid>

            <!-- OSC Address -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="OSCアドレス" VerticalAlignment="Center" Margin="0,0,0,10"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="OscAddressBox" FontFamily="Consolas" Margin="0,0,0,10" />

            <!-- Send Trigger Time as Seconds -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="TC秒数送信" VerticalAlignment="Center" Margin="0,0,0,10"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
            <CheckBox Grid.Row="4" Grid.Column="1" x:Name="SendTcSecondsBox"
                      Content="トリガー時間を秒数(float)で先頭引数に追加"
                      Margin="0,0,0,10" />

            <!-- OSC Arguments -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="OSC引数" VerticalAlignment="Center" Margin="0,0,0,10"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="OscArgsBox" FontFamily="Consolas" Margin="0,0,0,10"
                     ToolTip="例: i:1 f:0.5 s:hello (型:値 をスペース区切り)" />

            <!-- Target Hosts -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="送信先ホスト" VerticalAlignment="Top" Margin="0,0,0,10"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
            <ListBox Grid.Row="6" Grid.Column="1" x:Name="HostListBox"
                     Height="80" Margin="0,0,0,10"
                     SelectionMode="Multiple"
                     Background="{DynamicResource SecondaryBackgroundBrush}"
                     BorderBrush="{DynamicResource BorderSubtleBrush}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" Tag="{Binding Id}"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Foreground="{DynamicResource PrimaryForegroundBrush}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Memo -->
            <TextBlock Grid.Row="7" Grid.Column="0" Text="メモ" VerticalAlignment="Top" Margin="0,0,0,10"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
            <TextBox Grid.Row="7" Grid.Column="1" x:Name="MemoBox" Height="50"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />

            <!-- Enabled -->
            <CheckBox Grid.Row="8" Grid.Column="1" x:Name="EnabledBox" Content="有効" Margin="0,0,0,10" />

            <!-- Buttons -->
            <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2"
                        Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="OK" Padding="24,8" Margin="0,0,8,0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnOkClick" IsDefault="True" />
                <Button Content="キャンセル" Padding="24,8"
                        Click="OnCancelClick" IsCancel="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
