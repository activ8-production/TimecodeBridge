<Window x:Class="TimecodeBridge.Views.CueBatchEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="キュー一括編集"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        Foreground="{DynamicResource PrimaryForegroundBrush}">

    <Border Margin="12" Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
            CornerRadius="8" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" x:Name="HeaderText" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,0,0,12" />

            <!-- OSC Address -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="ApplyOscAddress" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="OSCアドレス" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                <TextBox Grid.Column="2" x:Name="OscAddressBox" FontFamily="Consolas"
                         IsEnabled="{Binding IsChecked, ElementName=ApplyOscAddress}" />
            </Grid>

            <!-- Send TC as Seconds -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="ApplySendTcSeconds" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="TC秒数送信" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                <CheckBox Grid.Column="2" x:Name="SendTcSecondsBox"
                          Content="トリガー時間を秒数(float)で先頭引数に追加"
                          IsEnabled="{Binding IsChecked, ElementName=ApplySendTcSeconds}" />
            </Grid>

            <!-- OSC Arguments -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="ApplyOscArgs" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="OSC引数" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                <TextBox Grid.Column="2" x:Name="OscArgsBox" FontFamily="Consolas"
                         ToolTip="例: i:1 f:0.5 s:hello (型:値 をスペース区切り)"
                         IsEnabled="{Binding IsChecked, ElementName=ApplyOscArgs}" />
            </Grid>

            <!-- Target Hosts -->
            <Grid Grid.Row="4" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="ApplyTargetHosts" VerticalAlignment="Top" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="送信先ホスト" VerticalAlignment="Top"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                <ListBox Grid.Column="2" x:Name="HostListBox"
                         Height="80" SelectionMode="Multiple"
                         IsHitTestVisible="{Binding IsChecked, ElementName=ApplyTargetHosts}"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         BorderBrush="{DynamicResource BorderSubtleBrush}">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=ApplyTargetHosts}" Value="False">
                                    <Setter Property="Opacity" Value="0.4" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" Tag="{Binding Id}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Foreground="{DynamicResource PrimaryForegroundBrush}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Cue Offset -->
            <Grid Grid.Row="5" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="ApplyOffset" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="キューオフセット" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                <Grid Grid.Column="2" IsEnabled="{Binding IsChecked, ElementName=ApplyOffset}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="OffsetSignBox" Width="44">
                        <ComboBoxItem Content="+" IsSelected="True" />
                        <ComboBoxItem Content="-" />
                    </ComboBox>
                    <TextBox Grid.Column="1" x:Name="OffsetHoursBox" TextAlignment="Center" MaxLength="2" Margin="4,0,0,0" FontFamily="Consolas" Text="00" />
                    <TextBlock Grid.Column="2" Text=":" VerticalAlignment="Center" Margin="4,0"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" />
                    <TextBox Grid.Column="3" x:Name="OffsetMinutesBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" Text="00" />
                    <TextBlock Grid.Column="4" Text=":" VerticalAlignment="Center" Margin="4,0"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" />
                    <TextBox Grid.Column="5" x:Name="OffsetSecondsBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" Text="00" />
                    <TextBlock Grid.Column="6" Text=":" VerticalAlignment="Center" Margin="4,0"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" />
                    <TextBox Grid.Column="7" x:Name="OffsetFramesBox" TextAlignment="Center" MaxLength="2" FontFamily="Consolas" Text="00" />
                </Grid>
            </Grid>

            <!-- Memo -->
            <Grid Grid.Row="6" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="ApplyMemo" VerticalAlignment="Top" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="メモ" VerticalAlignment="Top"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                <TextBox Grid.Column="2" x:Name="MemoBox" Height="50"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         IsEnabled="{Binding IsChecked, ElementName=ApplyMemo}" />
            </Grid>

            <!-- Enabled -->
            <Grid Grid.Row="7" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="ApplyEnabled" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="有効" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" />
                <CheckBox Grid.Column="2" x:Name="EnabledBox" Content="有効"
                          IsEnabled="{Binding IsChecked, ElementName=ApplyEnabled}" />
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="適用" Padding="24,8" Margin="0,0,8,0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnOkClick" IsDefault="True" />
                <Button Content="キャンセル" Padding="24,8"
                        Click="OnCancelClick" IsCancel="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
